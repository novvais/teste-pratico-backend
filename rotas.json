                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"client_name\": \"Eduardo Novais\",\n    \"client_email\": \"eduardo@betalent.tech\",\n    \"products\": [\n        { \"id\": 1, \"quantity\": 1 },\n        { \"id\": 2, \"quantity\": 2 }\n    ],\n    \"card\": {\n        \"number\": \"5569000000006063\",\n        \"last_four\": \"6063\",\n        \"expiration_month\": \"12\",\n        \"expiration_year\": \"2030\",\n        \"cvv\": \"010\"\n    }\n}",
                            "options": { "raw": { "language": "json" } }
